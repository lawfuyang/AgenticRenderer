struct Vertex
{
    float3 m_Pos;
    float3 m_Normal;
    float2 m_Uv;
    float4 m_Tangent;
};

struct VertexQuantized
{
    float3 m_Pos;
    uint   m_Normal;
    uint   m_Uv;
    uint   m_Tangent;
};

struct MeshData
{
    uint  m_LODCount;
    uint  m_IndexOffsets[8];
    uint  m_IndexCounts[8];
    uint  m_MeshletOffsets[8];
    uint  m_MeshletCounts[8];
    float m_LODErrors[8];
};

struct Meshlet
{
    uint m_CenterRadius[2];
    uint m_VertexOffset;
    uint m_TriangleOffset;
    uint m_VertexCount;
    uint m_TriangleCount;
    uint m_ConeAxisAndCutoff;
};

struct MeshletJob
{
    uint m_InstanceIndex;
    uint m_LODIndex;
};
